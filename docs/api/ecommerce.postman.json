{
  "info": {
    "name": "KalaKart API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "ml_url",   "value": "http://localhost:8001" },
    { "key": "access_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@kalakart.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Test User\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const res = pm.response.json();",
                "if (res.success) {",
                "  pm.collectionVariables.set('access_token', res.data.access_token);",
                "  console.log('Token set:', res.data.access_token.substring(0, 20) + '...');",
                "}"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@kalakart.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"YOUR_REFRESH_TOKEN\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "20" },
                { "key": "category", "value": "electronics", "disabled": true },
                { "key": "search",   "value": "headphones",  "disabled": true },
                { "key": "sort",     "value": "newest",      "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/wireless-headphones"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cart",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/cart/items",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 1\n}"
            }
          }
        },
        {
          "name": "Update Cart Item",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/cart/items/ITEM_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            }
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/cart/items/ITEM_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": {\n    \"full_name\": \"Test User\",\n    \"line1\": \"123 MG Road\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"postal_code\": \"400001\",\n    \"country\": \"IN\"\n  },\n  \"payment_intent_id\": \"pi_test_123\"\n}"
            }
          }
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/ORDER_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Intent",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/payments/intent",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/users/me",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Updated Name\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users/me/change-password",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"new_password\": \"newpassword123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/admin/orders",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/orders/ORDER_ID_HERE/status",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shipped\"\n}"
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/admin/products",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Product\",\n  \"description\": \"Product description here\",\n  \"price\": 99900,\n  \"category_id\": \"CATEGORY_ID_HERE\",\n  \"inventory_count\": 50\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/admin/products/PRODUCT_ID_HERE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 89900,\n  \"inventory_count\": 100\n}"
            }
          }
        },
        {
          "name": "Delete Product (soft)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/admin/products/PRODUCT_ID_HERE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }]
          }
        }
      ]
    },
    {
      "name": "ML Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/health"
          }
        },
        {
          "name": "Analyze Sentiment",
          "request": {
            "method": "POST",
            "url": "{{ml_url}}/sentiment",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"This product is absolutely amazing!\"\n}"
            }
          }
        },
        {
          "name": "Get Recommendations",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/recommend/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Get Inventory Forecast",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/forecast/PRODUCT_ID_HERE"
          }
        },
        {
          "name": "Get At-Risk Products",
          "request": {
            "method": "GET",
            "url": "{{ml_url}}/forecast/at-risk?risk_level=high"
          }
        }
      ]
    }
  ]
}