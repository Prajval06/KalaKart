FROM node:20-alpine

WORKDIR /app

# Copy package files first — layer caching means npm install
# only re-runs when package.json changes, not on every code change
COPY package*.json ./
RUN npm ci --only=production

COPY . .

EXPOSE 8000

CMD ["node", "src/server.js"]
```

