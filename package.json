{
  "scripts": {
    "dev": "cd backend && nodemon src/server.js",
    "start": "cd backend && node src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watchAll --runInBand",
    "test:cover": "jest --coverage --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "razorpay": "^2.9.6",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
