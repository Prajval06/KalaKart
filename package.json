{
  "name": "kalakart",
  "version": "1.0.0",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon backend/src/server.js",
    "start": "node backend/src/server.js",
    "test": "cd backend && jest --runInBand --forceExit",
    "test:watch": "cd backend && jest --watchAll --runInBand",
    "test:cover": "cd backend && jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "morgan": "^1.10.1",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterFramework": [
      "./backend/tests/setup.js"
    ],
    "testMatch": [
      "**/backend/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  }
}
