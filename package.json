{
  "name": "kalakart",
  "version": "1.0.0",
  "description": "KalaKart e-commerce platform",
  "main": "backend/src/server.js",
  "scripts": {
    "dev": "node --watch backend/src/server.js",
    "dev:nodemon": "npx --no-install nodemon backend/src/server.js",
    "start": "node backend/src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watchAll --runInBand",
    "test:cover": "jest --coverage --runInBand --forceExit",
    "seed:products": "node backend/src/seeds/seed.products.js"
  },
  "keywords": [
    "ecommerce",
    "artisan",
    "kalakart"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^6.7.0",
    "helmet": "^7.0.0",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^7.1.0",
    "mongoose": "^8.23.0",
    "morgan": "^1.10.0",
    "stripe": "^11.0.0"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "minimatch": "^3.1.2",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "./backend/tests/setup.js"
    ],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 30000
  }
}